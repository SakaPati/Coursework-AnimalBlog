<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import java.net.URL?>

<VBox spacing="15.0" prefWidth="500.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.io.github.fozeton.blog.controllers.PostDetail"
      styleClass="modal-container">

    <stylesheets>
        <URL value="@styles/postDetail.css" />
    </stylesheets>

    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="user-header">
        <ImageView fx:id="userAvatar" fitHeight="40" fitWidth="40" preserveRatio="true" styleClass="avatar-circle"/>
        <Text fx:id="userName" styleClass="author-name"/>
    </HBox>

    <Separator styleClass="light-separator"/>

    <ScrollPane fitToWidth="true" styleClass="content-scroll">
        <VBox spacing="15">
            <Text fx:id="modalTitle" styleClass="post-title"/>

            <StackPane styleClass="image-bg">
                <ImageView fx:id="modalImage" fitWidth="440.0" preserveRatio="true"/>
            </StackPane>

            <Text fx:id="modalContent" wrappingWidth="440.0" styleClass="post-description"/>

            <Separator styleClass="light-separator">
                <padding>
                    <Insets top="10" bottom="5"/>
                </padding>
            </Separator>

            <Label text="Комментарии" styleClass="section-label"/>

            <VBox fx:id="commentsContent" spacing="12" styleClass="comments-container"/>

            <Button fx:id="loadMoreBtn" text="Загрузить еще..." onAction="#loadNextComments"
                    maxWidth="Infinity" styleClass="load-more-button"/>
        </VBox>
    </ScrollPane>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="commentInput" HBox.hgrow="ALWAYS"
                   promptText="Напишите комментарий..." styleClass="comment-field"/>
        <Button text="Отправить" onAction="#handleAddComment" styleClass="send-button"/>
    </HBox>
</VBox>
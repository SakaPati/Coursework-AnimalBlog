<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="io.github.fozeton.blog.controllers.PostItemController"
      spacing="10" prefWidth="400.0"
      style="-fx-background-color: white; -fx-border-color: #dbdbdb; -fx-border-width: 0 0 1 0;">

    <padding>
        <Insets bottom="10.0" left="0.0" right="0.0" top="10.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <padding>
            <Insets left="10.0" right="10.0"/>
        </padding>
        <ImageView fx:id="userAvatar" fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
        </ImageView>
        <Text fx:id="postAuthor" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    </HBox>
    <Text fx:id="postTitle" style="-fx-font-weight: bold;"/>

    <VBox alignment="CENTER" style="-fx-background-color: #fafafa;">
        <ImageView fx:id="postImage" pickOnBounds="true" preserveRatio="true" fitWidth="400.0"/>
    </VBox>

    <Text fx:id="postContent" wrappingWidth="380.0"/>

    <VBox spacing="5">
        <padding>
            <Insets left="10.0" right="10.0"/>
        </padding>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Text fx:id="postLikeCount" />
            <Button onAction="#handleLikeClick" style="-fx-background-color: transparent; -fx-padding: 0;">
                <graphic>
                    <ImageView fx:id="postLike" fitHeight="24.0" fitWidth="24.0">
                        <Image url="@static/icons/like.png"/>
                    </ImageView>
                </graphic>
            </Button>
            <Text fx:id="postCommentCount" />
            <Button fx:id="postComment" style="-fx-background-color: transparent; -fx-padding: 0;">
                <graphic>
                    <ImageView fitHeight="24.0" fitWidth="24.0">
                        <Image url="@static/icons/comment.png"/>
                    </ImageView>
                </graphic>
            </Button>
        </HBox>

        <VBox fx:id="commentsContainer" spacing="3"/>
    </VBox>

</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.io.github.fozeton.blog.controllers.ProfileController"
      prefWidth="600.0"
      styleClass="profile-root">

    <stylesheets>
        <URL value="@styles/profile.css" />
    </stylesheets>

    <padding>
        <Insets top="20" right="50" bottom="30" left="50"/>
    </padding>

    <HBox>
        <Button text="← Назад к ленте" onAction="#goBack" styleClass="back-button"/>
    </HBox>

    <HBox spacing="40" alignment="CENTER_LEFT" styleClass="header-box">
        <StackPane onMouseClicked="#handleChangeAvatar" styleClass="avatar-container">
            <ImageView fx:id="userAvatar" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true"/>
        </StackPane>

        <VBox spacing="15" alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Text fx:id="userName" styleClass="user-name"/>
                <Text fx:id="postCount" styleClass="stats-text"/>
            </VBox>
            <Button text="Создать пост" onAction="#handleCreatePost" styleClass="create-post-button"/>
        </VBox>
    </HBox>

    <Region prefHeight="1" styleClass="separator"/>

    <ScrollPane fitToWidth="true" styleClass="posts-scroll">
        <TilePane fx:id="postsGrid" hgap="10" vgap="10" prefColumns="3" tileAlignment="TOP_LEFT"/>
    </ScrollPane>
</VBox>
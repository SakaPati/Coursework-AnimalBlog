<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="io.github.fozeton.blog.controllers.Register"
      prefHeight="400.0" prefWidth="600.0">

    <Text fx:id="registerTitle" text="Регистрация"/>
    <Label fx:id="errorLabel" text="Введите данные для регистрации!" textFill="red" visible="false"/>
    <TextField fx:id="registerLogin" promptText="Введите логин..."/>
    <PasswordField fx:id="registerPassword" promptText="Ваш пароль..."/>
    <PasswordField fx:id="repeatPassword" promptText="Повторите пароль..."/>
    <CheckBox fx:id="personalDataCheck"
              text="Я даю согласие на обработку персональных данных и принимаю Политику конфиденциальности"
    />
    <Button fx:id="registerButton" text="Создать аккаунт" onAction="#register"/>
</VBox>
